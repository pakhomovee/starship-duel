# /etc/starship/starship.env — Starship Duel service configuration.
# Copy to /etc/starship/starship.env, fill in the CHANGE_ME values, then:
#   sudo chown root:starship /etc/starship/starship.env
#   sudo chmod 640 /etc/starship/starship.env      # it holds secrets
# Loaded by both systemd units (starship-web, starship-worker).

# === REQUIRED: untrusted-bot isolation ======================================
# 'docker' = ALWAYS sandbox, and fail closed if docker is missing. Never use
# 'auto' or 'none' in production — those run strangers' code straight on the host.
STARSHIP_SANDBOX=docker

# Rootless Docker socket for the 'starship' user. Replace 1001 with the real uid:
#   id -u starship
XDG_RUNTIME_DIR=/run/user/1001
DOCKER_HOST=unix:///run/user/1001/docker.sock

# === data locations (persist outside the code checkout) =====================
STARSHIP_ACCOUNTS_DB=/var/lib/starship/accounts.db
STARSHIP_GAMES_DB=/var/lib/starship/games.db
STARSHIP_TOURNEY_DB=/var/lib/starship/tournament.db
STARSHIP_TOURNEY_BOTS=/var/lib/starship/arena_bots.json
STARSHIP_SUBMISSIONS_DIR=/var/lib/starship/submissions

# === seed admin (created once on first web start) ===========================
# After the first successful start, comment out STARSHIP_ADMIN_PASSWORD again —
# the account already exists and the hash is in the DB.
STARSHIP_ADMIN_USER=admin
STARSHIP_ADMIN_PASSWORD=CHANGE_ME_then_comment_out

# === admin token for CLI/cron write endpoints (schedule/recompute) ==========
# Generate:  openssl rand -hex 32
STARSHIP_ADMIN_TOKEN=CHANGE_ME

# === optional knobs =========================================================
# Shared access-token gate over ALL of /api. LEAVE UNSET for a public tournament
# (the account system does the gating). Set it only for a private beta.
# STARSHIP_ACCESS_TOKEN=

STARSHIP_MAX_SUBMISSIONS_PER_DAY=20
STARSHIP_MAX_LIVE_SESSIONS=32
STARSHIP_SESSION_IDLE_SECONDS=1800

# Per-bot sandbox resource caps
STARSHIP_SANDBOX_MEMORY_MB=256
STARSHIP_SANDBOX_CPUS=1.0
STARSHIP_SANDBOX_PIDS=128
# C++ compile container gets its own (larger) memory ceiling: cc1plus building
# the vendored nlohmann/json is OOM-killed at 256 MB. Don't drop this below ~768.
STARSHIP_SANDBOX_COMPILE_MEMORY_MB=1024

# Login throttle (per ip+username): lock out after N fails within the window.
STARSHIP_LOGIN_MAX_FAILS=10
STARSHIP_LOGIN_WINDOW_SECONDS=300

# Do NOT put DEEPSEEK_API_KEY (or any paid key) on a public host.
